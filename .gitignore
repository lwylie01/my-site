# Quarto / build output
/.quarto/
_site/
**/*.quarto_ipynb

# Generated periodic table (built from Excel by hiphop/build_table.R on render)
hiphop/hiphop_periodic_table.html

# Generated Barnum Test page (built from Excel by barnum/build_barnum.R on render)
barnum/barnum_test.html

# Generated How Old Is Old? page (built from Excel by howold/build_howold.R on render)
howold/how_old_is_old.html

# Generated Trust Your Gut? page (built from Excel by gut/build_gut.R on render)
gut/trust_your_gut.html

# Generated evaluation picker (built from Excel by evalpicker/build_eval.R on render)
evalpicker/eval_picker.html

# Internal/private working files — keep off the public site repo
CV/Wylie_Capacity_Dashboard.qmd
CV/Wylie_Capacity_Dashboard.html
CV/Wylie_Capacity_Dashboard_files/

# Local-only preview helper (machine-specific R path)
.claude/launch.json

# RStudio / R session files
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# Note: _freeze/ is generally tracked so unchanged R documents render from
# cache. Exception: hiphop/ has freeze disabled (hiphop/_metadata.yml) because
# its documents read from the Excel workbook — a frozen render would go stale
# on data-only edits.
_freeze/hiphop/

# Counted Wrong freeze cache: freeze is disabled (countedwrong/_metadata.yml)
# because the essay reads countedwrong/data/*.csv. Keep stray caches out.
_freeze/countedwrong/

# Internal capacity dashboard freeze cache — never publish (contains project details)
_freeze/CV/
